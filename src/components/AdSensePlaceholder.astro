---
interface Props {
	type: 'header' | 'sidebar' | 'in-article';
}

const { type } = Astro.props;

const dimensions = {
    'header': 'w-full h-[90px] md:h-[250px]',
    'sidebar': 'w-full h-[600px]',
    'in-article': 'w-full h-[250px] my-8'
};
---

<div class={`bg-gray-100 flex items-center justify-center border-2 border-dashed border-gray-300 text-gray-400 font-mono text-sm rounded ${dimensions[type]}`}>
    <span>[ AdSense Space: {type} ]</span>
</div>
