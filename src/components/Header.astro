---
import { SITE_TITLE, SUPPORTED_LANGS } from '../consts';

interface Props {
  currentLang?: string;
  translationSlugs?: Record<string, string>;
}
const { currentLang = 'en', translationSlugs } = Astro.props;

// Build the flag-URL lookup to embed in every page for client-side updates
const flagUrls = Object.fromEntries(SUPPORTED_LANGS.map(l => [l.code, l.flagImg]));
const currentFlagUrl = flagUrls[currentLang] ?? flagUrls['en'];
---

<header>
  <nav class="nav-inner container">
    <!-- Logo: owl image + SVG wordmark -->
    <a href="/" class="logo" aria-label="TrendSeek Home">
      <img
        src="/images/owl-logo.png"
        alt=""
        class="logo-owl"
        aria-hidden="true"
      />
      <svg
        class="logo-wordmark"
        viewBox="0 0 168 36"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        fill="none"
      >
        <defs>
          <!-- Radiant gradient for Seek -->
          <linearGradient id="seekGrad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#A78BFA"/>
            <stop offset="100%" stop-color="#C4B5FD"/>
          </linearGradient>
          <!-- Subtle glow to make it premium -->
          <filter id="wordmarkGlow" x="-20%" y="-20%" width="140%" height="140%">
            <feGaussianBlur stdDeviation="1.5" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>
        
        <!-- "TREND" in bright white -->
        <text x="0" y="27"
              font-family="'Montserrat', sans-serif"
              font-size="24" font-weight="900" letter-spacing="0"
              fill="white">TREND</text>
              
        <!-- Decorative glowing dot separator -->
        <circle cx="95" cy="19" r="3" fill="#00d4ff" opacity="0.9" filter="url(#wordmarkGlow)"/>
        
        <!-- "SEEK" in white (testing visibility) -->
        <text x="105" y="27"
              font-family="'Montserrat', sans-serif"
              font-size="24" font-weight="900" letter-spacing="0"
              fill="white">SEEK</text>
      </svg>
    </a>


    <!-- Language picker -->
    <div class="lang-wrap" id="lang-wrap">
      <button class="flag-btn" id="lang-btn" aria-haspopup="listbox" aria-expanded="false" title="Change language">
        <img
          id="current-flag-img"
          src={currentFlagUrl}
          alt={currentLang}
          width="24"
          height="18"
          class="flag-img"
        />
        <svg class="chevron" viewBox="0 0 10 6" width="10" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 1l4 4 4-4"/></svg>
      </button>

      <ul class="lang-menu" id="lang-menu" role="listbox">
        {SUPPORTED_LANGS.map(lang => {
          let href = `/?lang=${lang.code}`;
          if (translationSlugs && translationSlugs[lang.code]) {
            href = `/blog/${translationSlugs[lang.code]}/`;
          }
          return (
            <li role="option" aria-selected={lang.code === currentLang}>
              <a href={href} class={lang.code === currentLang ? 'active' : ''}>
                <img src={lang.flagImg} alt={lang.label} width="24" height="18" class="flag-img" />
                <span class="label">{lang.label}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </nav>
</header>

<!-- Pass flag URLs to client JS for dynamic updates -->
<script define:vars={{ flagUrls }}>
  // ── Toggle dropdown ──────────────────────────────────────────────────────
  const btn  = document.getElementById('lang-btn');
  const menu = document.getElementById('lang-menu');

  btn?.addEventListener('click', e => {
    e.stopPropagation();
    const open = menu?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(open));
  });
  document.addEventListener('click', () => {
    menu?.classList.remove('open');
    btn?.setAttribute('aria-expanded', 'false');
  });

  // ── Dynamic flag update ──────────────────────────────────────────────────
  // Called by page scripts (homepage geolocation, etc.) after detecting lang
  window.__setHeaderLang = function(langCode) {
    const img = document.getElementById('current-flag-img');
    const url = flagUrls[langCode];
    if (img && url) {
      img.src = url;
      img.alt = langCode;
    }
    // Highlight active item in dropdown
    document.querySelectorAll('#lang-menu a').forEach(a => {
      a.classList.toggle('active', a.getAttribute('href')?.includes(langCode) ?? false);
    });
  };
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(13,15,20,0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }

  /* Logo */
  .logo { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; }
  .logo-owl {
    height: 74px;
    width: auto;
    display: block;
    object-fit: contain;
    margin-top: 6px;
    margin-bottom: -16px;
    position: relative;
    z-index: 10;
  }
  .logo-wordmark {
    height: 40px;
    width: auto;
    display: block;
    overflow: visible;
  }

  /* Flag button */
  .lang-wrap { position: relative; }
  .flag-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 5px 8px;
    cursor: pointer;
    color: var(--text-muted);
    font-family: inherit;
    transition: border-color var(--transition);
    height: 34px;
  }
  .flag-btn:hover { border-color: var(--accent); }
  .flag-img {
    width: 24px;
    height: 18px;
    border-radius: 2px;
    object-fit: cover;
    display: block;
  }
  .chevron { opacity: 0.55; transition: transform var(--transition); }
  .flag-btn[aria-expanded="true"] .chevron { transform: rotate(180deg); }

  /* Dropdown */
  .lang-menu {
    display: none;
    position: absolute;
    right: 0;
    top: calc(100% + 6px);
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    list-style: none;
    padding: 4px;
    min-width: 155px;
    z-index: 200;
  }
  .lang-menu.open { display: block; }
  .lang-menu li { margin: 0; }
  .lang-menu a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 12px;
    border-radius: 6px;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    transition: background var(--transition), color var(--transition);
  }
  .lang-menu a:hover,
  .lang-menu a.active {
    background: var(--surface);
    color: #fff;
  }
</style>
