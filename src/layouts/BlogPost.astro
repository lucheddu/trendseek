---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, lang = 'en', heroImage, translationSlugs: rawSlugs } = Astro.props;

// Parse the JSON string safely
let parsedSlugs: Record<string, string> | undefined;
if (rawSlugs) {
  try { parsedSlugs = JSON.parse(rawSlugs); } catch {}
}

// Localized "by" and date labels
const authorLabels: Record<string, string> = {
  en: 'By', it: 'Di', es: 'Por', fr: 'Par'
};
const byLabel = authorLabels[lang] || 'By';

const authorBio: Record<string, string> = {
  en: 'Our editorial team delivers in-depth, well-researched articles on the most important trends shaping our world — from technology and finance to science and history.',
  it: 'Il nostro team editoriale offre articoli approfonditi e ben documentati sui trend più importanti che plasmano il nostro mondo — dalla tecnologia e finanza alla scienza e alla storia.',
  es: 'Nuestro equipo editorial ofrece artículos detallados y bien documentados sobre las tendencias más importantes que dan forma a nuestro mundo — desde tecnología y finanzas hasta ciencia e historia.',
  fr: 'Notre équipe éditoriale propose des articles approfondis et bien documentés sur les tendances les plus importantes qui façonnent notre monde — de la technologie et la finance à la science et l\'histoire.',
};
const bioText = authorBio[lang] || authorBio['en'];
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} image={heroImage} ogType="article" pubDate={pubDate} updatedDate={updatedDate} lang={lang} translationSlugs={parsedSlugs} />
  </head>
  <body>
    <Header currentLang={lang} translationSlugs={parsedSlugs} />

    <div class="article-layout container">
      <!-- ──── Main column ──── -->
      <main class="article-main">

        <!-- Hero image (inside column, contextual) -->
        {heroImage && (
          <div class="article-hero-img">
            <img src={heroImage} alt={title} loading="eager" />
          </div>
        )}

        <!-- Article header -->
        <header class="article-header">
          <h1 class="article-h1">{title}</h1>
          <div class="article-meta">
            <span class="badge">{lang.toUpperCase()}</span>
            <span class="meta-sep">·</span>
            <span class="author">{byLabel} <strong>TrendSeek Editorial</strong></span>
            <span class="meta-sep">·</span>
            <time datetime={pubDate?.toISOString()}>
              <FormattedDate date={pubDate} />
            </time>
            {updatedDate && (
              <span class="updated">
                (Updated: <FormattedDate date={updatedDate} />)
              </span>
            )}
          </div>
          <p class="article-desc">{description}</p>
          <hr />
        </header>

        <!-- Article body -->
        <div class="prose" id="article-prose">
          <slot />
        </div>

        <!-- Author box -->
        <div class="author-box">
          <img src="/images/owl-logo.png" alt="TrendSeek" class="author-avatar" />
          <div class="author-info">
            <strong>TrendSeek Editorial</strong>
            <p>{bioText}</p>
          </div>
        </div>

      </main>

      <!-- ──── Sidebar ──── -->
      <aside class="article-sidebar">
        <!-- Sidebar content can go here in the future -->
      </aside>
    </div>

    <Footer />
  </body>
</html>

<style>
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2rem;
    padding-top: 2rem;
    padding-bottom: 4rem;
    align-items: start;
  }
  @media (max-width: 900px) {
    .article-layout { grid-template-columns: 1fr; }
    .article-sidebar { display: none; }
  }
  .article-main { min-width: 0; }

  /* Hero image banner — contained, not full-bleed */
  .article-hero-img {
    width: 100%;
    max-height: 260px;
    overflow: hidden;
    border-radius: var(--radius-lg);
    margin-bottom: 1.75rem;
    border: 1px solid var(--border);
  }
  .article-hero-img img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    display: block;
  }

  /* Article header */
  .article-header { margin-bottom: 2rem; }
  .article-h1 {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: 0.75rem;
    letter-spacing: -0.025em;
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .meta-sep { opacity: 0.4; }
  .author { color: var(--text-muted); }
  .updated { opacity: 0.7; font-size: 0.8rem; }
  .article-desc {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.65;
    font-style: italic;
    margin-bottom: 1.5rem;
  }

  /* Author box */
  .author-box {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-top: 3rem;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .author-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: contain;
    flex-shrink: 0;
    background: rgba(255,255,255,0.05);
  }
  .author-info strong {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 0.95rem;
  }
  .author-info p {
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.55;
    margin: 0;
  }

  /* Sticky sidebar */
  .article-sidebar {
    align-self: start;
    position: sticky;
    top: 96px;
    max-height: calc(100vh - 96px);
  }
</style>
