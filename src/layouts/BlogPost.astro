---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, lang = 'en', heroImage, translationSlugs: rawSlugs } = Astro.props;

// Parse the JSON string safely
let parsedSlugs: Record<string, string> | undefined;
if (rawSlugs) {
  try { parsedSlugs = JSON.parse(rawSlugs); } catch {}
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header currentLang={lang} translationSlugs={parsedSlugs} />

    <!-- Hero image banner -->
    {heroImage && (
      <div style="display:none" class="article-hero-img" id="hero-placeholder-outside"></div>
    )}

    <div class="article-layout container">
      <!-- ──── Main column ──── -->
      <main class="article-main">
        <!-- Leaderboard ad just below header -->
        <div class="ad-slot ad-slot--leaderboard">[AdSense – Leaderboard 728×90]</div>

        <!-- Hero image (inside column, contextual) -->
        {heroImage && (
          <div class="article-hero-img">
            <img src={heroImage} alt={title} loading="eager" />
          </div>
        )}

        <!-- Article header -->
        <header class="article-header">
          <h1 class="article-h1">{title}</h1>
          <div class="article-meta">
            <span class="badge">{lang.toUpperCase()}</span>
            <FormattedDate date={pubDate} />
            {updatedDate && <span class="updated"> · Updated <FormattedDate date={updatedDate} /></span>}
          </div>
          <p class="article-desc">{description}</p>
          <hr />
        </header>

        <!-- Article body – ads injected between §§ by JS below -->
        <div class="prose" id="article-prose">
          <slot />
        </div>

        <!-- Bottom ad -->
        <div class="ad-slot ad-slot--in-article">[AdSense – Bottom Rectangle]</div>
      </main>

      <!-- ──── Sticky sidebar ──── -->
      <aside class="article-sidebar">
        <div class="ad-slot ad-slot--sidebar">[AdSense – Sidebar 300×600]</div>
      </aside>
    </div>

    <Footer />

    <!-- ──── Inject AdSense slots with proper spacing ──── -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const prose = document.getElementById('article-prose');
        if (!prose) return;

        const children = Array.from(prose.children);
        const totalBlocks = children.length;
        if (totalBlocks < 6) return; // Too short for any ads

        // Strategy: insert up to 3 ads, evenly spaced through the article.
        // Minimum gap of 4 content blocks between ads.
        const MAX_ADS = 3;
        const MIN_GAP = 4; // minimum content blocks between ads

        // Calculate ideal insertion points: divide article into MAX_ADS+1 segments
        const segmentSize = Math.max(MIN_GAP, Math.floor(totalBlocks / (MAX_ADS + 1)));
        const insertPoints = [];

        for (let i = 1; i <= MAX_ADS; i++) {
          const idealIdx = i * segmentSize;
          if (idealIdx >= totalBlocks - 2) break; // don't insert near the very end

          // Find the nearest paragraph to insert after (prefer after <p>, avoid after <h1>-<h6>)
          let bestIdx = idealIdx;
          for (let j = idealIdx; j >= Math.max(0, idealIdx - 2); j--) {
            if (children[j].tagName === 'P') { bestIdx = j; break; }
          }
          // If no paragraph found looking back, look forward
          if (children[bestIdx].tagName !== 'P') {
            for (let j = idealIdx + 1; j < Math.min(totalBlocks, idealIdx + 3); j++) {
              if (children[j].tagName === 'P') { bestIdx = j; break; }
            }
          }

          // Ensure minimum gap from previous insertion
          if (insertPoints.length > 0 && bestIdx - insertPoints[insertPoints.length - 1] < MIN_GAP) {
            bestIdx = insertPoints[insertPoints.length - 1] + MIN_GAP;
            if (bestIdx >= totalBlocks - 2) break;
          }

          insertPoints.push(bestIdx);
        }

        // Insert ads in reverse order so indices don't shift
        insertPoints.reverse().forEach(idx => {
          const el = children[idx];
          if (!el) return;
          const adDiv = document.createElement('div');
          adDiv.className = 'ad-slot ad-slot--in-article ad-inline';
          adDiv.textContent = '[AdSense – In-Article]';
          el.after(adDiv);
        });
      });
    </script>
  </body>
</html>

<style>
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2rem;
    padding-top: 2rem;
    padding-bottom: 4rem;
    align-items: start;
  }
  @media (max-width: 900px) {
    .article-layout { grid-template-columns: 1fr; }
    .article-sidebar { display: none; }
  }
  .article-main { min-width: 0; }

  /* Hero image banner — contained, not full-bleed */
  .article-hero-img {
    width: 100%;
    max-height: 260px;
    overflow: hidden;
    border-radius: var(--radius-lg);
    margin-bottom: 1.75rem;
    border: 1px solid var(--border);
  }
  .article-hero-img img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    display: block;
  }

  /* Article header */
  .article-header { margin-bottom: 2rem; }
  .article-h1 {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: 0.75rem;
    letter-spacing: -0.025em;
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .updated { opacity: 0.7; }
  .article-desc {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.65;
    font-style: italic;
    margin-bottom: 1.5rem;
  }

  /* Inline ads between paragraphs */
  :global(.ad-inline) {
    margin: 1.5rem 0 !important;
    height: 120px !important;
    border-radius: var(--radius);
  }

  /* Sticky sidebar ad */
  .article-sidebar {
    align-self: start;   /* critical: prevents grid stretch that breaks sticky */
    position: sticky;
    top: 96px;           /* 80px header + 16px breathing room */
    max-height: calc(100vh - 96px);
  }
  .article-sidebar .ad-slot {
    /* no need for sticky here, the parent aside is sticky */
  }
</style>
